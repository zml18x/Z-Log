{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "SqlLiteConnection": "Data Source=zLog.db"
  },

  "MigrationsSettings": {
    "MaxRetries": 3,
    "Delay": 10
  },

  "Jwt": {
    "Secret": "fvh8456477hth44j6wfds98bq9hp8bqh9ubq9gjig3qr0[94vj5';'OFLJ'ASpoddasJR[Q]WPUFD9231OI19PFa9fdas]9U'",
    "Issuer": "ZLog.WebApi",
    "Audience": "ZLog.Client",
    "AccessTokenExpirationMinutes": 5,
    "RefreshTokenExpirationDays": 7
  },

  "Resend": {
    "ApiKey": "",
    "FromEmail": "",
    "FromName": "Z-Log"
  },
  
  "Frontend": {
    "BaseUrl": "https://localhost:3000"
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/all.log",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/errors.log",
          "restrictedToMinimumLevel": "Error",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "ZLog"
    }
  }
}